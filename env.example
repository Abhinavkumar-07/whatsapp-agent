# Get a free Groq API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# The "personality" / instructions for your AI agent
SYSTEM_PROMPT=You are a helpful, friendly assistant replying to WhatsApp messages on behalf of the account owner. Keep replies short and natural, like a real text message.

# Optional: only auto-reply to these numbers (comma-separated, with country code, no + or spaces)
# Leave empty to reply to everyone
ALLOWED_NUMBERS=

# Optional: ignore group chats (true/false)
IGNORE_GROUPS=true

# --- Quiet Hours ---
# During these hours, the AI won't auto-reply (uses your computer's local time, 24hr format)
QUIET_HOURS_ENABLED=false
QUIET_HOURS_START=23
QUIET_HOURS_END=7
# Optional: if set, sends this message once instead of staying silent during quiet hours
QUIET_HOURS_MESSAGE=

# --- Forward notifications to yourself ---
# If enabled, every incoming message + the AI's reply gets forwarded to your own WhatsApp
# (sent as a message to yourself, e.g. via the "You" chat), so you always see what's happening
NOTIFY_ENABLED=false
# Your own number with country code, no + or spaces (e.g. 15551234567)
NOTIFY_NUMBER=
