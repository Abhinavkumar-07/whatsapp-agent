# ─── Required ─────────────────────────────────────────────────────────────────

# Get a free Groq API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ─── AI Models (optional — defaults shown) ────────────────────────────────────

# Text / chat model (used for all text replies)
GROQ_TEXT_MODEL=llama-3.3-70b-versatile

# Vision model (used when someone sends an image)
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Whisper model (used for voice note transcription)
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# ─── AI Behaviour ─────────────────────────────────────────────────────────────

# The "personality" / instructions for your AI agent
SYSTEM_PROMPT=You are a helpful, friendly assistant replying to WhatsApp messages on behalf of the account owner. Keep replies short and natural, like a real text message.

# How many previous messages the AI can see (context window per chat)
MAX_CONVERSATION_HISTORY=10

# Truncate incoming messages longer than this many characters (prevents prompt abuse)
MAX_MESSAGE_LENGTH=2000

# ─── Filtering ────────────────────────────────────────────────────────────────

# Optional: only auto-reply to these numbers (comma-separated, country code, no + or spaces)
# Leave blank to reply to everyone
ALLOWED_NUMBERS=

# Ignore group chats (true/false)
IGNORE_GROUPS=true

# ─── Rate Limiting ────────────────────────────────────────────────────────────

# Max messages per chat per window before the bot stops responding
RATE_LIMIT_MAX=10

# Window size in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# ─── Quiet Hours ─────────────────────────────────────────────────────────────

# During these hours the AI won't auto-reply (uses your computer's local time, 24h)
QUIET_HOURS_ENABLED=false
QUIET_HOURS_START=23
QUIET_HOURS_END=7

# Optional: send this message once per quiet window instead of staying silent
QUIET_HOURS_MESSAGE=

# ─── Forward Notifications ───────────────────────────────────────────────────

# Set true to receive a WhatsApp message-to-self for every incoming message
NOTIFY_ENABLED=false

# Your own number with country code, no + or spaces (e.g. 15551234567)
NOTIFY_NUMBER=

# ─── Personality ──────────────────────────────────────────────────────────────

# Probability (0–1) of reacting with just an emoji for short/casual messages
# 0 = never react, 1 = always react, 0.5 = half the time (default)
EMOJI_REACTION_CHANCE=0.5

# ─── Logging ─────────────────────────────────────────────────────────────────

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
