{
  "name": "whatsapp-ai-agent",
  "version": "1.1.0",
  "description": "Free AI auto-reply agent for WhatsApp using Baileys + Groq (Llama, Whisper, vision)",
  "main": "index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "test": "node --test test/**/*.test.js",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "format": "prettier --write src/ test/ index.js",
    "format:check": "prettier --check src/ test/ index.js"
  },
  "keywords": [
    "whatsapp",
    "ai",
    "chatbot",
    "groq",
    "llama",
    "baileys",
    "automation",
    "whisper"
  ],
  "license": "MIT",
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.9",
    "dotenv": "^16.4.5",
    "pino": "^9.4.0",
    "qrcode-terminal": "^0.12.0"
  },
  "optionalDependencies": {
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  }
}
